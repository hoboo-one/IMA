{
  "name": "product-storyboard-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "worker"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "worker:dev": "npm run dev -w worker",
    "worker:build": "npm run build -w worker",
    "worker:start": "npm run start -w worker",
    "ci": "npm run db:generate && npm run typecheck && npm run lint && npm run worker:build"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.2",
    "clsx": "^2.1.1",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.7",
    "prisma": "^6.18.0",
    "typescript": "^5.9.3"
  }
}
